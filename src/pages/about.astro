---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<header>
			<h1>About Me</h1>
			<p>A student-athlete at Fort Lewis College pursuing Computer Information Systems.</p>
			<p class="page-links">
				<a href="/">Go to Home Page</a>
			</p>
		</header>

		<section>
			<h2>Who I Am</h2>
			<p>
				I am a student at Fort Lewis College where I balance academics and athletics as a
				member of the soccer program. I am currently studying Computer Information Systems,
				building skills in technology, business systems, and problem-solving.
			</p>
			<p>
				Soccer has taught me discipline, teamwork, and leadership, while my CIS studies are
				helping me prepare for a career in the tech field.
			</p>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		font-family: Georgia, serif;
		color: #222;
	}

	header {
		background-color: #1a6b2f;
		color: #fff;
		padding: 2rem 1.25rem;
		border-radius: 8px;
		margin-bottom: 2rem;
		text-align: center;
	}

	header h1 {
		margin: 0 0 0.5rem;
		font-size: 2.25rem;
	}

	header p {
		margin: 0;
		font-size: 1.05rem;
		opacity: 0.95;
	}

	.page-links {
		margin-top: 1rem;
	}

	.page-links a {
		display: inline-block;
		padding: 0.5rem 0.8rem;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.2);
		color: #fff;
		text-decoration: none;
		font-weight: 600;
	}

	.page-links a:hover,
	.page-links a:focus-visible {
		background: rgba(255, 255, 255, 0.3);
	}

	section {
		background: #f9f9f9;
		border-left: 5px solid #1a6b2f;
		padding: 1.5rem;
		border-radius: 8px;
	}

	h2 {
		margin-top: 0;
		color: #1a6b2f;
	}

	p {
		line-height: 1.7;
	}
</style>
